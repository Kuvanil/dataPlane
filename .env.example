# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/dataplane
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres

# ── Celery / Redis ─────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://broker:6379/0
CELERY_RESULT_BACKEND=redis://broker:6379/0
REDIS_HOST=broker
REDIS_PORT=6379

# ── Ollama LLM ─────────────────────────────────────────────────────────────────
# Host where Ollama is running.
# On macOS/Windows Docker Desktop use host.docker.internal; on Linux use the host IP.
OLLAMA_HOST=http://host.docker.internal:11434
# Model to use for all LLM calls (must be pulled in Ollama first: `ollama pull llama3`)
OLLAMA_MODEL=llama3
# Per-request timeout in seconds
OLLAMA_TIMEOUT=15
# Number of retries (with exponential backoff) on transient Ollama failures
OLLAMA_MAX_RETRIES=2

# ── Auth / Security ────────────────────────────────────────────────────────────
# REQUIRED in production — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string
# JWT expiry in minutes (default: 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480
# Default admin password — CHANGE before first deploy
ADMIN_DEFAULT_PASSWORD=admin123

# ── Frontend ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Schema Drift ───────────────────────────────────────────────────────────────
# How often (in minutes) to check for schema changes via Celery Beat
SCHEMA_DRIFT_INTERVAL_MINUTES=60

# ── ACI.dev external tool-calling integration (requirements-specs-v4) ─────────
# Optional. Leave ACI_API_KEY unset to disable the integration entirely.
# Self-host ACI with: git clone https://github.com/aipotheosis-labs/aci vendor/aci
# then: docker compose --profile aci up -d
ACI_BASE_URL=http://aci:8000
ACI_API_KEY=
# ACI's dev portal (OAuth-connect for external apps happens THERE, not in dataPlane)
ACI_PORTAL_URL=http://localhost:3001
ACI_LINKED_ACCOUNT_OWNER_ID=dataplane
# The ONE fixed internal Slack channel the auto-capable notify action may post to.
# Never user-suppliable at request time. Empty = notify-out disabled.
ACI_SLACK_INTERNAL_CHANNEL=
# Used in notification links back to dataPlane's own approval UI
DATAPLANE_BASE_URL=http://localhost:3000
# OpenAI key for the self-hosted ACI service's own tool-search embeddings
ACI_SERVER_OPENAI_API_KEY=

# ── Connector credential vaulting (requirements-specs-v5) ─────────────────────
# Backend: aes256 (self-hosted envelope encryption, zero external infra) or
# keeper (Keeper Secrets Manager — external zero-knowledge vault).
SECRET_MANAGER_BACKEND=aes256
# aes256: base64 32-byte key. Generate: openssl rand -base64 32
# Leaving it empty keeps legacy mode (secrets in config, responses redacted).
SECRETS_ENCRYPTION_KEY=
# Set only during a key-rotation window so existing rows stay decryptable.
SECRETS_ENCRYPTION_KEY_PREVIOUS=
# keeper: path to the mounted KSM client config produced by Keeper's
# one-time-token bootstrap (e.g. /run/secrets/ksm_config.json). NEVER commit
# the file itself — add it to .gitignore.
KSM_CONFIG_PATH=
KSM_FOLDER_UID=
